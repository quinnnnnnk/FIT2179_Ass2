{
  "width": "container",
  "height": 390,
  "data": {
    "url": "data/city_category_heatmap.csv"
  },
  "params": [
    {
      "name": "categoryPick05",
      "value": "All groups",
      "bind": {
        "input": "select",
        "options": [
          "Alcohol & tobacco",
          "All groups",
          "Clothing & footwear",
          "Communication",
          "Education",
          "Food & non-alcoholic beverages",
          "Furnishings, household equipment and services",
          "Health",
          "Housing",
          "Insurance & financial services",
          "Recreation & culture",
          "Transport"
        ],
        "name": "Category: "
      }
    }
  ],
  "transform": [
    {
      "filter": "datum.category == categoryPick05"
    },
    {
      "filter": "datum.city != 'Weighted average of eight capital cities'"
    }
  ],
  "mark": {
    "type": "rect",
    "cornerRadius": 3
  },
  "encoding": {
    "x": {
      "field": "city",
      "type": "nominal",
      "title": "Capital city"
    },
    "y": {
      "field": "category",
      "type": "nominal",
      "title": null
    },
    "color": {
      "field": "annual_pct",
      "type": "quantitative",
      "title": "Annual movement (%)",
      "scale": {
        "scheme": "orangered"
      }
    },
    "tooltip": [
      {
        "field": "category"
      },
      {
        "field": "city"
      },
      {
        "field": "annual_pct",
        "title": "Annual movement (%)",
        "format": ".1f"
      }
    ]
  },
  "title": {
    "text": "Capital City CPI Heatmap by Category",
    "subtitle": "Select a CPI category to compare annual movements across capital cities",
    "anchor": "start"
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    },
    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    }
  },
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json"
}
